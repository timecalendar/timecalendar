            "type": "number",
            "description": "The number of students the school has",
            "example": 10000
          },
          "domains": {
            "description": "The domains of study the school is known for\nIf should contain maximum 5 domains",
            "example": [
              "Informatique",
              "Electronique",
              "Marketing Digital"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "excellenceTitle": {
            "type": "string",
            "description": "The title of the excellence of the school",
            "example": "Excellence en Informatique"
          },
          "excellenceDescription": {
            "type": "string",
            "description": "A paragraph explaining why the school is known for the domains",
            "example": "\"L\"université My Gaming Academia est connue pour son excellence en informatique et en électronique.\""
