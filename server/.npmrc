# @lyrolab/nest-shared hard-declares peerDependencies for every module it ships
# (ai / @openrouter/ai-sdk-provider / @nestjs/passport / cache-manager …), but we
# only adopt its database/redis/bull/filter/health modules. Under npm 7+'s strict
# peer resolution those unused peers would (a) error — @openrouter/ai-sdk-provider
# wants ai@^6 while we pin ai@^5 — and (b) be auto-installed, pulling the AI /
# @nestjs-passport / cache peer stack we never import into the image.
# legacy-peer-deps restores npm 6 behaviour: don't auto-install peers, warn
# instead of erroring on unmet ones. The database-path peers we DO use (typeorm,
# @nestjs/{config,typeorm}, pg, …) are all present as real deps, so they resolve
# normally. (nest-shared's own runtime *dependencies* — e.g. passport / passport-
# jwt — still install; legacy-peer-deps only governs peers, not hard deps.)
legacy-peer-deps=true
