# ── Build the generated TypeScript API client ────────────────────────────────
# openapi/javascript has a self-contained package.json, so it builds standalone
# without the npm workspace.
FROM node:22 AS openapi
WORKDIR /app
COPY openapi ./openapi/
WORKDIR /app/openapi/javascript
RUN npm run build

# ── Install workspace dependencies ───────────────────────────────────────────
# web and openapi/javascript are npm workspace members of the repo-root
# package.json, so dependencies install from the single root lockfile.
FROM node:22-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json package-lock.json ./
COPY web/package.json ./web/
COPY openapi/javascript/package.json ./openapi/javascript/
RUN npm ci --legacy-peer-deps

# ── Build the Next.js app ────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/ ./
COPY web/ ./web/
COPY openapi/ ./openapi/
# The freshly built api-client dist is authoritative — copy it last.
COPY --from=openapi /app/openapi/javascript/dist ./openapi/javascript/dist
WORKDIR /app/web
RUN npm run build

# ── Runtime image ────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs
# With the workspace root as the Turbopack root, Next's standalone bundle spans
# web/ (server.js + its node_modules) and a root-level node_modules/ for
# workspace-hoisted runtime deps (sharp, client-only, …). Copy the whole tree.
COPY --from=builder --chown=nextjs:nodejs /app/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/web/public ./web/public
COPY --from=builder --chown=nextjs:nodejs /app/web/.next/static ./web/.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
CMD ["node", "web/server.js"]
